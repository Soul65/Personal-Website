{
	"name": "my-personal-website",
	"version": "1.0.0",
	"private": true,
	"description": "A personal portfolio website with static HTML, CSS, and JS",
	"main": "index.html",
	"keywords": [
		"portfolio",
		"site",
		"html",
		"css",
		"js"
	],
	"author": "Matt Allen (https://github.com/Soul65)",
	"homepage": "https://github.com/Soul65/Personal-Website",
	"license": "MIT",
	"type": "module",
	"scripts": {
		"start": "vite --host",
		"build": "vite build",
		"lint": "eslint .",
		"lint:types": "npx tsc",
		"preview": "vite preview",
		"format": "npx prettier . --write",
		"ncu": "ncu",
		"ncu:update": "ncu -u && pnpm install",
		"ncu:update:minor": "ncu -u -t minor && pnpm install"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.3",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.2.0",
		"autoprefixer": "^10.5.0",
		"eslint": "^9.39.4",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.5.2",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"postcss": "^8.5.10",
		"postcss-preset-mantine": "^1.18.0",
		"postcss-simple-vars": "^7.0.1",
		"prettier": "^3.8.2",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.2",
		"vite": "^7.3.2",
		"vite-tsconfig-paths": "^6.1.1"
	},
	"dependencies": {
		"@mantine/core": "^9.0.2",
		"@mantine/hooks": "^9.0.2",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"react-snowfall": "^2.4.0",
		"zustand": "^5.0.12"
	},
	"lint-staged": {
		"*.{js,css,html}": "pnpm run format",
		"*.{js,ts,tsx}": "pnpm run lint",
		"*.{ts,tsx}": "bash -c 'pnpm run lint:types'"
	},
	"packageManager": "pnpm@10.33.0"
}
