{
	"name": "my-personal-website",
	"version": "1.0.0",
	"private": true,
	"description": "A personal portfolio website with static HTML, CSS, and JS",
	"main": "index.html",
	"keywords": [
		"portfolio",
		"site",
		"html",
		"css",
		"js"
	],
	"author": "Matt Allen (https://github.com/Soul65)",
	"homepage": "https://github.com/Soul65/Personal-Website",
	"license": "MIT",
	"type": "module",
	"scripts": {
		"start": "vite --host",
		"build": "vite build",
		"lint": "eslint .",
		"lint:types": "npx tsc",
		"preview": "vite preview",
		"format": "npx prettier . --write",
		"update:deps": "pnpm up --latest",
		"update:deps:global": "pnpm up -g --latest"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"autoprefixer": "^10.5.0",
		"eslint": "^10.3.0",
		"eslint-plugin-react-hooks": "^7.1.1",
		"eslint-plugin-react-refresh": "^0.5.2",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.5",
		"postcss": "^8.5.14",
		"postcss-preset-mantine": "^1.18.0",
		"postcss-simple-vars": "^7.0.1",
		"prettier": "^3.8.3",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.2",
		"vite": "^8.0.13",
		"vite-tsconfig-paths": "^6.1.1"
	},
	"dependencies": {
		"@mantine/core": "^9.1.1",
		"@mantine/hooks": "^9.1.1",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"react-snowfall": "^2.4.0",
		"zustand": "^5.0.13"
	},
	"lint-staged": {
		"*.{js,css,html}": "pnpm run format",
		"*.{js,ts,tsx}": "pnpm run lint",
		"*.{ts,tsx}": "bash -c 'pnpm run lint:types'"
	},
	"packageManager": "pnpm@11.0.9"
}
